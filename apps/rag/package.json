{
  "name": "bochile-rag",
  "version": "1.0.0",
  "description": "RAG layer para Camila: embedea el catalogo de propiedades de Bochile en Qdrant y expone API de similarity search con filtros estrictos. Elimina la divagacion del Matcher.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "embed": "tsx src/embed.ts",
    "enrich": "tsx src/enricher.ts",
    "upload-sheet": "tsx src/upload-enriched-to-sheet.ts",
    "search": "tsx src/search.ts",
    "build": "echo 'no build needed - tsx runtime'",
    "start": "tsx src/server.ts"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.12.0",
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^171.4.0",
    "openai": "^4.62.0",
    "p-limit": "^6.1.0",
    "zod": "^3.23.8",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0"
  }
}
