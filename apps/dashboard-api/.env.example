# RENDER ONLY: contenido completo del service-account.json en una sola linea
# GOOGLE_SHEETS_CREDS_JSON={"type":"service_account",...}

CACHE_TTL_SECONDS=30
ALLOW_ORIGIN=http://localhost:5175
