{
  "name": "bochile-scraper",
  "version": "1.0.0",
  "description": "Scraper del catalogo de propiedades de bochile.com via sitemap + microdatos schema.org. Sale a JSON/CSV, postea webhook o sube directo al Google Sheet del sistema operativo.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "scrape": "tsx src/index.ts run",
    "test": "vitest run"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^4.4.1",
    "googleapis": "^144.0.0",
    "p-limit": "^6.1.0",
    "undici": "^6.19.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
