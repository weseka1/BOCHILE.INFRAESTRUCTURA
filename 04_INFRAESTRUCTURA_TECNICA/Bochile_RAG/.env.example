# ─────────────────────────────────────────────────────────────────────
# OpenAI (embeddings + Cami)
# ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─────────────────────────────────────────────────────────────────────
# Qdrant
#
# LOCAL (desarrollo en tu PC con docker compose):
#   QDRANT_URL=http://localhost:6333
#   QDRANT_API_KEY=
#
# QDRANT CLOUD (producción, free tier 1 GB):
#   QDRANT_URL=https://abcd-xxxx.us-east.aws.cloud.qdrant.io:6333
#   QDRANT_API_KEY=<key del cluster, lo da el dashboard de cloud.qdrant.io>
# ─────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=bochile_properties

# ─────────────────────────────────────────────────────────────────────
# Modelo de embeddings (no cambiar a menos que sepas lo que hacés)
# ─────────────────────────────────────────────────────────────────────
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# ─────────────────────────────────────────────────────────────────────
# Path al JSON enriquecido del scraper
#
# LOCAL: ../Bochile_Scraper/output/properties-enriched.json
# RENDER: ./output/properties-enriched.json (committeado al repo)
# ─────────────────────────────────────────────────────────────────────
SCRAPER_OUTPUT_JSON=../Bochile_Scraper/output/properties-enriched.json

# ─────────────────────────────────────────────────────────────────────
# Server REST
# ─────────────────────────────────────────────────────────────────────
SERVER_PORT=3003
ALLOW_ORIGIN=*

# ─────────────────────────────────────────────────────────────────────
# HMAC secret de respond.io (para validar webhooks entrantes)
# Obtener: respond.io → Settings → Integrations → Webhooks → Clave de firma
# ─────────────────────────────────────────────────────────────────────
RESPONDIO_WEBHOOK_SECRET=
